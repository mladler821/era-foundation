rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && getUserRole() in ['admin', 'editor'];
    }

    // Years + grants: authenticated read, editor write
    match /years/{year} {
      allow read: if isAuthenticated();
      allow write: if isEditor();

      match /grants/{grantId} {
        allow read: if isAuthenticated();
        allow write: if isEditor();
      }
    }

    // Grantees: authenticated read, editor write
    match /grantees/{granteeId} {
      allow read: if isAuthenticated();
      allow write: if isEditor();
    }

    // Commitments: authenticated read, editor write
    match /commitments/{commitmentId} {
      allow read: if isAuthenticated();
      allow write: if isEditor();
    }

    // Documents: authenticated read, editor write
    match /documents/{docId} {
      allow read: if isAuthenticated();
      allow write: if isEditor();
    }

    // Users: can read own profile, admin can read all
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
      // WHY: Allow first-time login to create own profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
