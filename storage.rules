rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // WHY: Only authenticated users can read/write files.
    // Max 25MB per file as specified in the doc storage requirements.
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
